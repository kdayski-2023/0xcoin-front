# Реальный API (когда бэкенд включён)
# REACT_APP_API_URL=https://api.example.com

# Режим моков: true — не ходить в сеть к API (удобно без бэкенда)
# REACT_APP_API_MOCK=true

# Если REACT_APP_API_URL не задан, моки включаются автоматически.

# Демо-учётка для /login → /admin (переопределите при необходимости)
# REACT_APP_MOCK_ADMIN_EMAIL=admin@0xcoin.local
# REACT_APP_MOCK_ADMIN_PASSWORD=admin123
# REACT_APP_MOCK_ACCESS_TOKEN=mock-jwt-0xcoin-local-dev
